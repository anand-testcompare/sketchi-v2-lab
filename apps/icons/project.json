{
  "name": "icons",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/icons/src",
  "projectType": "application",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/.output"],
      "options": {
        "command": "vite build --config apps/icons/vite.config.ts"
      }
    },
    "build-storybook": {
      "executor": "@nx/storybook:build",
      "outputs": ["{workspaceRoot}/storybook-static/icons"],
      "options": {
        "configDir": "apps/icons/.storybook",
        "outputDir": "storybook-static/icons"
      }
    },
    "cf-typegen": {
      "executor": "nx:run-commands",
      "options": {
        "command": "wrangler types --config apps/icons/wrangler.jsonc"
      }
    },
    "deploy": {
      "executor": "nx:run-commands",
      "dependsOn": ["build"],
      "options": {
        "command": "wrangler deploy --config dist/server/wrangler.json"
      }
    },
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "command": "vite dev --config apps/icons/vite.config.ts --host 127.0.0.1 --port 6203"
      }
    },
    "preview": {
      "executor": "nx:run-commands",
      "options": {
        "command": "vite preview --config apps/icons/vite.config.ts --host 127.0.0.1 --port 6303"
      }
    },
    "storybook": {
      "executor": "@nx/storybook:storybook",
      "options": {
        "configDir": "apps/icons/.storybook",
        "port": 6009
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/coverage/apps/icons"],
      "options": {
        "command": "vitest run --config apps/icons/vitest.config.ts"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc -p apps/icons/tsconfig.json --noEmit"
      }
    },
    "typecheck-tsgo": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsgo -p apps/icons/tsconfig.json --noEmit"
      }
    }
  }
}

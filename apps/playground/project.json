{
  "name": "playground",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/playground/src",
  "projectType": "application",
  "implicitDependencies": [
    "diagram-core",
    "diagram-excalidraw",
    "diagram-renderer",
    "diagram-scenarios",
    "diagram-studio-ui"
  ],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/.output"],
      "options": {
        "command": "vite build --config apps/playground/vite.config.ts"
      }
    },
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "command": "vite dev --config apps/playground/vite.config.ts --host 127.0.0.1 --port 6200"
      }
    },
    "preview": {
      "executor": "nx:run-commands",
      "options": {
        "command": "vite preview --config apps/playground/vite.config.ts --host 127.0.0.1 --port 6300"
      }
    },
    "deploy": {
      "executor": "nx:run-commands",
      "dependsOn": ["build"],
      "options": {
        "command": "wrangler deploy --config dist/server/wrangler.json"
      }
    },
    "cf-typegen": {
      "executor": "nx:run-commands",
      "options": {
        "command": "wrangler types --config apps/playground/wrangler.jsonc"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/coverage/apps/playground"],
      "options": {
        "command": "vitest run --config apps/playground/vitest.config.ts"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc -p apps/playground/tsconfig.json --noEmit"
      }
    },
    "typecheck-tsgo": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsgo -p apps/playground/tsconfig.json --noEmit"
      }
    }
  }
}

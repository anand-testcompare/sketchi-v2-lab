{
  "name": "diagram-excalidraw",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/diagram-excalidraw/src",
  "projectType": "library",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/dist"],
      "options": {
        "command": "tsc -p packages/diagram-excalidraw/tsconfig.lib.json"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/coverage/packages/diagram-excalidraw"],
      "options": {
        "command": "vitest run --config packages/diagram-excalidraw/vitest.config.mts"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc -p packages/diagram-excalidraw/tsconfig.json --noEmit"
      }
    },
    "typecheck-tsgo": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsgo -p packages/diagram-excalidraw/tsconfig.json --noEmit"
      }
    }
  }
}

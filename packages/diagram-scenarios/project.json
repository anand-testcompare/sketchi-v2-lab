{
  "name": "diagram-scenarios",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/diagram-scenarios/src",
  "projectType": "library",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/dist"],
      "options": {
        "command": "tsc -p packages/diagram-scenarios/tsconfig.lib.json"
      }
    },
    "scenario": {
      "executor": "nx:run-commands",
      "dependsOn": ["build"],
      "options": {
        "command": "node packages/diagram-scenarios/dist/cli.js"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/coverage/packages/diagram-scenarios"],
      "options": {
        "command": "vitest run --config packages/diagram-scenarios/vitest.config.mts"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc -p packages/diagram-scenarios/tsconfig.json --noEmit"
      }
    },
    "typecheck-tsgo": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsgo -p packages/diagram-scenarios/tsconfig.json --noEmit"
      }
    }
  }
}
